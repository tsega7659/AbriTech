generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

////////////////////
// ENUMS
////////////////////

enum RoleName {
  admin
  teacher
  student
  parent
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum EnrollmentStatus {
  active
  completed
}

enum SubmissionType {
  file
  link
  text
}

enum SubmissionStatus {
  draft
  pending
  approved
  rejected
}

enum ResultStatus {
  pass
  fail
}

enum NotificationType {
  assignment
  grade
  event
  suggestion
  system
}

enum LessonAccessType {
  free
  preview
  locked
  paid
}

enum ProjectStatus {
  pending
  approved
  rejected
}

enum PaymentStatus {
  pending
  success
  failed
}

enum EventType {
  hackathon
  summer_camp
  competition
  deadline
}

////////////////////
// ROLES & USERS
////////////////////

model Role {
  id    Int      @id @default(autoincrement())
  name  RoleName @unique

  users User[]

  @@map("role")
}

model User {
  id           BigInt   @id @default(autoincrement())
  fullName     String
  gender       String?
  age          Int?

  username     String   @unique
  email        String   @unique
  passwordHash String

  phoneNumber  String?
  parentPhone  String?
  address      String?

  roleId       Int
  role         Role     @relation(fields: [roleId], references: [id])

  student      Student?
  parent       Parent?

  // Gamification
  points       Int      @default(0)
  streak       Int      @default(0)

  notifications Notification[]
  blogs         Blog[]
  aiChats       AIChatLog[]
  teacherCourses TeacherCourse[]
  
  // Portfolios & Payments
  portfolio     Portfolio?
  payments      Payment[]
  eventRegistrations EventRegistration[]
  badges        UserBadge[]

  activeAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@map("user")
}

////////////////////
// STUDENTS & PARENTS
////////////////////

model Student {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt   @unique
  user              User     @relation(fields: [userId], references: [id])

  isCurrentStudent  Boolean
  classLevel        String?
  educationLevel    String?
  schoolName        String?

  courseLevel       CourseLevel

  parentEmail       String?
  referralCode      String?  @unique

  enrollments       Enrollment[]
  lessonProgress    LessonProgress[]
  quizAttempts      QuizAttempt[]
  assignmentSubs    AssignmentSubmission[]
  projects          Project[]

  parents           ParentStudent[]

  @@map("student")
}

model Parent {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique
  user              User     @relation(fields: [userId], references: [id])

  students  ParentStudent[]

  @@map("parent")
}

model ParentStudent {
  id        BigInt   @id @default(autoincrement())
  parentId  BigInt
  studentId BigInt

  parent    Parent   @relation(fields: [parentId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@map("parentstudent")
}

////////////////////
// COURSES & TEACHERS
////////////////////

model Course {
  id          BigInt      @id @default(autoincrement())
  name        String
  category    String
  level       CourseLevel

  youtubeLink String
  image       String?
  description String?
  
  // Pricing & Meta
  duration    String?
  price       Float?      @default(0)
  isFree      Boolean     @default(true)
  discount    Float?      @default(0)
  scholarshipAvailable Boolean @default(false)

  lessons     Lesson[]
  enrollments Enrollment[]
  assignments Assignment[]
  teacherCourses TeacherCourse[]
  payments     Payment[]

  createdAt   DateTime @default(now())

  @@map("course")
}

model TeacherCourse {
  id        BigInt @id @default(autoincrement())
  teacherId BigInt
  courseId  BigInt

  teacher   User   @relation(fields: [teacherId], references: [id])
  course    Course @relation(fields: [courseId], references: [id])

  @@map("teachercourse")
}

////////////////////
// ENROLLMENT & PROGRESS
////////////////////

model Enrollment {
  id                 BigInt           @id @default(autoincrement())
  studentId          BigInt
  courseId           BigInt

  progressPercentage Float            @default(0)
  timeSpentSeconds   Int              @default(0)
  status             EnrollmentStatus @default(active)
  finalGrade         String?

  student            Student @relation(fields: [studentId], references: [id])
  course             Course  @relation(fields: [courseId], references: [id])

  certificate        Certificate?

  enrolledAt         DateTime @default(now())

  @@map("enrollment")
}

model Lesson {
  id          BigInt @id @default(autoincrement())
  courseId    BigInt
  title       String
  description String
  summaryText String?
  orderNumber Int
  
  accessType  LessonAccessType @default(locked)

  course      Course @relation(fields: [courseId], references: [id])

  progress    LessonProgress[]
  quizzes     LessonQuiz[]
  aiSummary   LessonAISummary?
  aiChatLogs  AIChatLog[]

  @@map("lesson")
}

model LessonProgress {
  id         BigInt   @id @default(autoincrement())
  studentId  BigInt
  lessonId   BigInt

  completed  Boolean @default(false)
  completedAt DateTime?

  student    Student @relation(fields: [studentId], references: [id])
  lesson     Lesson  @relation(fields: [lessonId], references: [id])

  @@map("lessonprogress")
}

////////////////////
// QUIZZES
////////////////////

model LessonQuiz {
  id            BigInt @id @default(autoincrement())
  lessonId      BigInt
  question      String

  optionA       String
  optionB       String
  optionC       String
  optionD       String

  correctOption String
  maxAttempts   Int    @default(2)

  lesson        Lesson @relation(fields: [lessonId], references: [id])
  attempts      QuizAttempt[]

  @@map("lessonquiz")
}

model QuizAttempt {
  id            BigInt       @id @default(autoincrement())
  studentId     BigInt
  quizId        BigInt

  selectedOption String
  isCorrect      Boolean
  attemptNumber  Int
  result         ResultStatus

  student        Student    @relation(fields: [studentId], references: [id])
  quiz           LessonQuiz @relation(fields: [quizId], references: [id])

  attemptedAt    DateTime @default(now())

  @@map("quizattempt")
}

////////////////////
// ASSIGNMENTS & PROJECTS
////////////////////

model Assignment {
  id               BigInt @id @default(autoincrement())
  courseId         BigInt
  title            String
  description      String
  dueDate          DateTime?
  requiresApproval Boolean @default(true)
  maxPoints        Int     @default(100)

  course           Course @relation(fields: [courseId], references: [id])
  submissions      AssignmentSubmission[]

  @@map("assignment")
}

model AssignmentSubmission {
  id               BigInt @id @default(autoincrement())
  assignmentId     BigInt
  studentId        BigInt

  submissionType   SubmissionType
  submissionContent String

  status           SubmissionStatus @default(pending)
  result           ResultStatus?
  score            Float?
  maxScore         Int              @default(100)
  feedback         String?

  assignment       Assignment @relation(fields: [assignmentId], references: [id])
  student          Student    @relation(fields: [studentId], references: [id])

  submittedAt      DateTime @default(now())

  @@map("assignmentsubmission")
}

model Project {
  id               BigInt        @id @default(autoincrement())
  studentId        BigInt
  title            String
  description      String
  image            String?
  video            String?
  files            String?       // URL or JSON string for multiple files
  githubLink       String?
  
  status           ProjectStatus @default(pending)
  score            Float?
  feedback         String?
  
  student          Student       @relation(fields: [studentId], references: [id])
  
  submittedAt      DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("project")
}

////////////////////
// PORTFOLIOS & CERTIFICATES
////////////////////

model Portfolio {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @unique
  user         User     @relation(fields: [userId], references: [id])
  
  bio          String?
  isPublished  Boolean  @default(false)
  linkedIn     String?
  github       String?
  website      String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("portfolio")
}

model Certificate {
  id               BigInt     @id @default(autoincrement())
  enrollmentId     BigInt     @unique
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id])
  
  verificationCode String     @unique
  issuedAt         DateTime   @default(now())

  @@map("certificate")
}

////////////////////
// PAYMENTS
////////////////////

model Payment {
  id             BigInt        @id @default(autoincrement())
  userId         BigInt
  courseId       BigInt
  amount         Float
  currency       String        @default("ETB")
  provider       String        @default("Telebirr")
  transactionId  String?       @unique
  status         PaymentStatus @default(pending)
  
  user           User          @relation(fields: [userId], references: [id])
  course         Course        @relation(fields: [courseId], references: [id])
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("payment")
}

////////////////////
// EVENTS
////////////////////

model Event {
  id           BigInt             @id @default(autoincrement())
  title        String
  description  String
  type         EventType
  date         DateTime
  location     String?
  registerLink String?
  
  registrations EventRegistration[]
  
  createdAt    DateTime           @default(now())

  @@map("event")
}

model EventRegistration {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt
  eventId    BigInt
  
  user       User     @relation(fields: [userId], references: [id])
  event      Event    @relation(fields: [eventId], references: [id])
  
  registeredAt DateTime @default(now())

  @@map("eventregistration")
}

////////////////////
// GAMIFICATION
////////////////////

model Badge {
  id          BigInt      @id @default(autoincrement())
  name        String      @unique
  description String
  image       String
  
  users       UserBadge[]

  @@map("badge")
}

model UserBadge {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  badgeId   BigInt
  
  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])
  
  awardedAt DateTime @default(now())

  @@map("userbadge")
}

////////////////////
// AI FEATURES
////////////////////

model LessonAISummary {
  id        BigInt @id @default(autoincrement())
  lessonId  BigInt @unique
  aiSummary String

  lesson    Lesson @relation(fields: [lessonId], references: [id])

  createdAt DateTime @default(now())

  @@map("lessonaisummary")
}

model AIChatLog {
  id          BigInt @id @default(autoincrement())
  userId      BigInt
  lessonId    BigInt?

  userMessage String
  aiResponse  String

  user        User    @relation(fields: [userId], references: [id])
  lesson      Lesson? @relation(fields: [lessonId], references: [id])

  createdAt   DateTime @default(now())

  @@map("aichatlog")
}

////////////////////
// NOTIFICATIONS
////////////////////

model Notification {
  id        BigInt @id @default(autoincrement())
  userId    BigInt

  title     String
  message   String
  type      NotificationType @default(system)

  isRead    Boolean @default(false)

  user      User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("notification")
}

////////////////////
// BLOGS
////////////////////

model Blog {
  id          BigInt @id @default(autoincrement())
  title       String
  content     String
  coverImage  String?
  isPublished Boolean @default(true)

  createdBy   BigInt
  author      User @relation(fields: [createdBy], references: [id])

  createdAt   DateTime @default(now())

  @@map("blog")
}
