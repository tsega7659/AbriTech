# --- Chapa / payments ---
# Secret from Chapa dashboard (API tab) — server only, never commit real keys.
CHAPA_SECRET_KEY=

# Same value as Chapa dashboard → Webhooks → "Secret hash" (used to verify x-chapa-signature).
CHAPA_WEBHOOK_SECRET=

# Public URL of the student React app (no trailing slash). Used for Chapa return_url after checkout.
# Production example: https://your-student-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Public HTTPS URL of this API (no trailing slash). Chapa must be able to POST to:
#   {BACKEND_PUBLIC_URL}/api/payments/chapa/webhook
# On Render, RENDER_EXTERNAL_URL is often set automatically; you can still set this explicitly.
# Local dev: use ngrok (https://xxxx.ngrok.io) — Chapa cannot reach http://localhost.
BACKEND_PUBLIC_URL=
